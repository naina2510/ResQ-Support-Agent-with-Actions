# Template only. Safe to commit. Never put a real key in this file.
#
# Local:    copy this to .streamlit/secrets.toml and paste your keys there.
#           secrets.toml is gitignored, so it won't be committed.
# Deployed: don't create the file. Paste both lines below into
#           Streamlit Cloud > App > Settings > Secrets instead.
#
# GROQ_API_KEY runs the chat model. GOOGLE_API_KEY is still needed because
# the knowledge base embeddings run on Gemini.

GROQ_API_KEY = "paste-your-groq-key-here"
GOOGLE_API_KEY = "paste-your-gemini-key-here"